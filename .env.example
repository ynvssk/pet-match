# ── Database ───────────────────────────────────────────────
# Local dev: Docker Postgres (DIRECT_URL == DATABASE_URL).
# Supabase prod:
#   DATABASE_URL = Connection Pooling string (port 6543) + ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = Direct connection string (port 5432) — used for migrations.
DATABASE_URL="postgresql://petmate:petmate@localhost:5432/petmate?schema=public"
DIRECT_URL="postgresql://petmate:petmate@localhost:5432/petmate?schema=public"

# ── Auth ───────────────────────────────────────────────────
JWT_SECRET="generate-a-strong-secret-of-at-least-32-characters"

NODE_ENV="development"

# ── Supabase Storage (leave blank to use local disk uploads) ─
# From Supabase dashboard → Project Settings → API.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="pet-photos"
